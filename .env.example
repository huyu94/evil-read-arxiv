APP_PORT=3000

# MySQL on NAS. Use an address reachable from the cloud server/container.
MYSQL_HOST=your-nas-host-or-ip
MYSQL_PORT=3306
MYSQL_USER=evil_read_arxiv
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=evil_read_arxiv
MYSQL_CONNECTION_LIMIT=10

# MinIO on NAS. Do not include http:// or https:// in MINIO_ENDPOINT.
MINIO_ENDPOINT=your-nas-host-or-ip
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=evil_read_arxiv
MINIO_SECRET_KEY=change_me_minio
MINIO_BUCKET=evil-read-arxiv

# AI analysis
ANTHROPIC_API_KEY=change_me
ANTHROPIC_BASE_URL=

# Daily crawl behavior
DAILY_PAPER_COUNT=10
# Defaults to all daily papers in parallel. Set this to throttle PDF downloads.
PDF_UPLOAD_CONCURRENCY=
